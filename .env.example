# ============================================================
# Trader Copilot AI — environment template
# Copy to .env and adjust. Never commit the real .env.
# ============================================================

# ---- Core ----
ENV=development
LOG_LEVEL=INFO

# ---- Database (PostgreSQL) ----
# Inside docker-compose the host is the service name "db".
# For running the backend on the host directly, use localhost.
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader
POSTGRES_DB=trader_copilot
DATABASE_URL=postgresql+psycopg://trader:trader@db:5432/trader_copilot

# ---- Auth / JWT ----
# Generate a strong secret for real environments, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me-please-0123456789abcdef
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Frontend origin (CORS, credentials) ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- Storage (local FS in MVP) ----
SCREENSHOT_DIR=./storage/screenshots

# ---- Market data provider (M7) ----
# stub = local session only, indicators "unknown" (MVP default)
MARKET_DATA_PROVIDER=stub

# ---- AI (M9+) ----
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
